rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Users collection
    match /users/{userId} {
      allow read, write: if true;
    }
    match /users/{document=**} {
      allow read, write: if true;
    }

    // 2. Admin settings (Global configuration)
    match /adminSettings/{document=**} {
      allow read, write: if true;
    }

    // 3. Tasks configuration
    match /tasks/{document=**} {
      allow read, write: if true;
    }

    // 4. User task completions
    match /userTasks/{document=**} {
      allow read, write: if true;
    }

    // 5. Referrals
    match /referrals/{document=**} {
      allow read, write: if true;
    }

    // 6. Withdraw requests
    match /withdrawRequests/{document=**} {
      allow read, write: if true;
    }

    // 7. Audit logs
    match /auditLogs/{document=**} {
      allow read, write: if true;
    }

    // 8. Security events
    match /securityEvents/{document=**} {
      allow read, write: if true;
    }
  }
}
