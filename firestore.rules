rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection
    // - Any authenticated user can read their own document
    // - Allow write only for own document
    // - Admin (specific email) can read/write all user documents
    match /users/{userId} {
      // Allow user to read/write their own data
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Allow admin (by email) full access to all user documents
      allow read, write: if request.auth != null &&
        request.auth.token.email == 'sourav.sanyal.dev@gmail.com';
    }

    // Allow admin to list/query all users
    match /users/{document=**} {
      allow read, write: if request.auth != null &&
        request.auth.token.email == 'sourav.sanyal.dev@gmail.com';
    }

    // Allow unauthenticated writes for Telegram mini app users
    // (Telegram WebApp doesn't use Firebase Auth — users write their own docs)
    match /users/{userId} {
      allow create, update: if true;
      allow read: if request.auth != null;
    }
  }
}
