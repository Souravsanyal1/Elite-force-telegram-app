rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      // Telegram mini app users write their own docs (no Firebase Auth needed)
      allow create, update: if true;

      // Any authenticated user reads their own doc
      allow read: if request.auth != null && request.auth.uid == userId;

      // Admin email can read/write all user documents
      allow read, write: if request.auth != null &&
        request.auth.token.email == 'sourav.sanyal.dev@gmail.com';
    }

    // Admin can query/list the entire users collection
    match /users/{document=**} {
      allow read, write: if request.auth != null &&
        request.auth.token.email == 'sourav.sanyal.dev@gmail.com';
    }
  }
}
